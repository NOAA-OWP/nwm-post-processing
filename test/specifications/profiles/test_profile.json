{
    "configuration": "short_range",
    "output_type": "channel_rt",
    "region": "conus",
    "comment": "This should simulate an operation that adds upstream flow to each file and separately combines all output and splits them by RFC",
    "operations": [
        {
            "operation": "drop",
            "exclude": true,
            "fields": ["feature_id", "time", "reference_time", "streamflow", "crs"]
        },
        {
            "operation": "on_each",
            "comment": "Add upstreamflow to each input file by calling 'post_processing.transform.calculate_upstream_flow.calculate_upstream_flow' on each",
            "on_each": [
                {
                    "operation": "function",
                    "function_name": "post_processing.transform.calculate_upstream_flow.calculate_upstream_flow",
                    "comment": "This should end up calling `calculate_upstream_flow(input_path=data, output_path=data, routelink_path='{application_path}/RouteLink_CONUS.nc')`",
                    "kwargs": {
                        "routelink_path": "{application_path}/test/data/routelink/{Configuration}.{ModelOutputType}.{Region}.nc",
                        "routelink_from_variable": "from",
                        "output_path": "{work_directory}/upstream.{input_name}"
                    },
                    "argument_mapping": {
                        "input_path": "data"
                    }
                }
            ]
        },
        {
            "operation": "merge",
            "file_name_pattern": "nwm.t{reference_time__date}{cycle}z.{ModelOutputType}.{Configuration}.{Region}.nc"
        },
        {
            "operation": "rename",
            "mapping": {
                "feature_id": "station_id"
            }
        },
        {
            "operation": "extract",
            "dimension": "station_id",
            "mask_coordinate": "feature_id",
            "masks": [
                "test/data/masks/short_range.channel_rt.conus/*"
            ],
            "identifier_pattern": "^(?P<region>\\w+(\\.(?P<rfc>[MmAaLlCcNnPpWwOoSsHh][BbPpNnMmAaCcEeWwHhRrGg]([Rr][Ff][Cc]|[Vv][Ii])))?)",
            "output_pattern": "nwm.t{reference_time__date}{cycle}z.{Configuration}.{ModelOutputType}.{region}.nc",
            "each": [
                {
                    "operation": "save",
                    "filename_pattern": "{file_name}",
                    "directory": "{output_path}/nwm.{reference_time__date}"
                }
            ]
        }
    ]
}
