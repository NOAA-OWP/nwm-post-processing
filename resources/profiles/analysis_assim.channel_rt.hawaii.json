{
    "operations": [
        {
            "operation": "drop",
            "exclude": true,
            "fields": ["feature_id", "time", "reference_time", "streamflow", "crs"]
        },
        {
            "operation": "adjust_dimensions",
            "mapping": {
                "streamflow": ["feature_id", "time"]
            }
        },
        {
            "operation": "branch",
            "branches": {
                "WMS": [
                    {
                        "operation": "unit_conversion",
                        "conversions": [
                            {
                                "variable_name": "streamflow",
                                "target_unit": "ft3 s-1"
                            }
                        ]
                    },
                    {
                        "operation": "save",
                        "filename_pattern": "nwm.t{cycle}z.{Configuration}.{ModelOutputType}.tm{tminus}.{Region}.nc",
                        "directory": "{output_path}/"
                    }
                ],
                "RFC": [
                    {
                        "operation": "on_each",
                        "comment": "Add upstreamflow to each input file by calling 'post_processing.transform.calculate_upstream_flow.calculate_upstream_flow' on each",
                        "on_each": [
                            {
                                "operation": "function",
                                "function_name": "post_processing.transform.calculate_upstream_flow.calculate_upstream_flow_binned",
                                "comment": "This should end up calling `calculate_upstream_flow(input_path=data, output_path=data, routelink_path='{application_path}/RouteLink_CONUS.nc')`",
                                "kwargs": {
                                    "routelink_path": "{routelink_path}/RouteLink_HI.nc",
                                    "routelink_from_variable": "link",
                                    "output_path": "{work_directory}/upstream.{input_name}"
                                },
                                "argument_mapping": {
                                    "input_path": "data"
                                }
                            }
                        ]
                    },
                    {
                        "operation": "rename",
                        "mapping": {
                            "feature_id": "station_id"
                        }
                    },
                    {
                        "operation": "rename",
                        "rename_variable": false,
                        "mapping": {
                            "feature_id": "station"
                        }
                    },
                    {
                        "operation": "extract",
                        "dimension": "station_id",
                        "mask_coordinate": "feature_id",
                        "masks": [
                            "{mask_path}/aprfc.nc"
                        ],
                        "identifier_pattern": "^(?P<region>\\w+(\\.(?P<rfc>[MmAaLlCcNnPpWwOoSsHh][BbPpNnMmAaCcEeWwHhRrGg]([Rr][Ff][Cc]|[Vv][Ii])))?)",
                        "output_pattern": "nwm.t{cycle}z.{Configuration}.{ModelOutputType}.{frame}.hawaii.aprfc.nc",
                        "each": [
                            {
                                "operation": "save",
                                "filename_pattern": "nwm.t{cycle}z.{Configuration}.{ModelOutputType}.{frame}.hawaii.aprfc.nc",
                                "directory": "{output_path}/"
                            }
                        ]
                    }
                ]
            }
        }
    ],
    "configuration": "analysis_assim",
    "output_type": "channel_rt",
    "region": "hawaii",
    "member": null
}
