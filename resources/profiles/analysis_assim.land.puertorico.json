{
    "operations": [
        {
            "operation": "drop",
            "exclude": true,
            "fields": [
                "x",
                "y",
                "time",
                "reference_time",
                "crs",
                "ACCET",
                "SOILSAT_TOP",
                "FSNO",
                "SNEQV",
                "SNOWH",
                "SNOWT_AVG"
            ]
        },
        {
            "operation": "branch",
            "branches": {
                "WMS": [
                    {
                        "operation": "reproject",
                        "reference_dataset_path": "{resource_path}/projections/prvi_mercator.nc"
                    },
                    {
                        "operation": "save",
                        "filename_pattern": "nwm.t{cycle}z.{Configuration}.{ModelOutputType}.tm{tminus}.puertorico.nc",
                        "directory": "{output_path}/",
                        "include_conditions": {
                            "tminus": "00"
                        }
                    }
                ],
                "RFC": [
                    {
                        "operation": "reproject",
                        "reference_dataset_path": "{resource_path}/projections/prvi_sphere_lambert.nc"
                    },
                    {
                        "operation": "save",
                        "filename_pattern": "nwm.t{cycle}z.{Configuration}.{ModelOutputType}.tm{tminus}.puertorico.serfc.nc",
                        "directory": "{output_path}/"
                    }
                ]
            }
        }
    ],
    "configuration": "analysis_assim",
    "output_type": "land",
    "region": "puertorico",
    "member": null
}
