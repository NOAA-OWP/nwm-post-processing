{
    "operations": [
        {
            "operation": "drop",
            "exclude": true,
            "fields": ["feature_id", "time", "reference_time", "streamflow", "crs"]
        },
        {
            "operation": "anomaly",
            "variable_name": "streamflow",
            "default_score": 3,
            "output_pattern": "anomaly.nwm.t{cycle}z.{Configuration}.{ModelOutputType}_{member}.{frame}.{region}.nc",
            "time_variable": "time",
            "dimension_names": "feature_id",
            "output_variable_name": "streamflow_anomaly",
            "comment": "The previous version of CONUS excluded the 50th percentile, so this will as well. Data from in (25th, 75th] is the IQR, which is considered 'fairly normal'. This variable is for identifying 'weird' values, so the IQR is set at a value of '0.0'",
            "thresholds": [
                {
                    "data_path": "{threshold_path}/p05.nc",
                    "level": -5.0,
                    "variable": "streamflow_0_4"
                },
                {
                    "data_path": "{threshold_path}/p10.nc",
                    "level": -3.0,
                    "variable": "streamflow_5_9"
                },
                {
                    "data_path": "{threshold_path}/p25.nc",
                    "level": -1.25,
                    "variable": "streamflow_10_24"
                },
                {
                    "data_path": "{threshold_path}/p75.nc",
                    "level": 0.0,
                    "variable": "streamflow_50_75"
                },
                {
                    "data_path": "{threshold_path}/p90.nc",
                    "level": 0.5,
                    "variable": "streamflow_76_90"
                },
                {
                    "data_path": "{threshold_path}/p95.nc",
                    "level": 1.5,
                    "variable": "streamflow_91_95"
                }
            ]
        },
        {
            "operation": "echo",
            "message": "Calculated Anomaly, now calculating upstreamflow",
            "level": "INFO"
        },
        {
            "operation": "on_each",
            "comment": "Add upstreamflow to each input file by calling 'post_processing.transform.calculate_upstream_flow.calculate_upstream_flow' on each",
            "on_each": [
                {
                    "operation": "function",
                    "function_name": "post_processing.transform.calculate_upstream_flow.calculate_upstream_flow",
                    "comment": "This should end up calling `calculate_upstream_flow(input_path=data, output_path=data, routelink_path='{application_path}/RouteLink_CONUS.nc')`",
                    "kwargs": {
                        "routelink_path": "{routelink_path}/RouteLink_CONUS.nc",
                        "routelink_from_variable": "link",
                        "output_path": "{work_directory}/upstream.{input_name}"
                    },
                    "argument_mapping": {
                        "input_path": "data"
                    }
                }
            ]
        },
        {
            "operation": "merge",
            "file_name_pattern": "nwm.t{cycle}z.{Configuration}.{ModelOutputType}_{member}.{Region}.nc"
        },
        {
            "operation": "branch",
            "branches": {
                "WMS": [
                    {
                        "operation": "drop",
                        "fields": ["upstreamflow"],
                        "output_pattern": "no_upstream.nwm.t{cycle}z.{Configuration}.{ModelOutputType}_{member}.{Region}.nc"
                    },
                    {
                        "operation": "unit_conversion",
                        "conversions": [
                            {
                                "variable_name": "streamflow",
                                "target_unit": "ft3 s-1"
                            }
                        ]
                    },
                    {
                        "operation": "save",
                        "filename_pattern": "nwm.t{cycle}z.{Configuration}.{ModelOutputType}_{member}.{Region}.nc",
                        "directory": "{output_path}/"
                    }
                ],
                "RFC": [
                    {
                        "operation": "drop",
                        "fields": ["streamflow_anomaly"]
                    },
                    {
                        "operation": "rename",
                        "mapping": {
                            "feature_id": "station_id"
                        }
                    },
                    {
                        "operation": "rename",
                        "rename_variable": false,
                        "mapping": {
                            "feature_id": "station"
                        }
                    },
                    {
                        "operation": "extract",
                        "dimension": "station_id",
                        "mask_coordinate": "feature_id",
                        "masks": [
                            "{mask_path}/abrfc.nc",
                            "{mask_path}/c*rfc.nc",
                            "{mask_path}/m*rfc.nc",
                            "{mask_path}/lmrfc.nc",
                            "{mask_path}/n*rfc.nc",
                            "{mask_path}/ohrfc.nc",
                            "{mask_path}/serfc.nc",
                            "{mask_path}/wgrfc.nc"
                        ],
                        "identifier_pattern": "^(?P<region>\\w+(\\.(?P<rfc>[MmAaLlCcNnPpWwOoSsHh][BbPpNnMmAaCcEeWwHhRrGg]([Rr][Ff][Cc]|[Vv][Ii])))?)",
                        "output_pattern": "nwm.t{cycle}z.{Configuration}.{ModelOutputType}_{member}.{region}.nc",
                        "each": [
                            {
                                "operation": "save",
                                "filename_pattern": "{file_name}",
                                "identifier_pattern": "(?P<rfc>[A-Za-z]{2}[Rr][Ff][Cc])",
                                "directory": "{output_path}/"
                            }
                        ]
                    }
                ]
            }
        }
    ],
    "configuration": "long_range",
    "output_type": "channel_rt",
    "region": "conus",
    "member": "4"
}
