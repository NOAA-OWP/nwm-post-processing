{
    "operations": [
        {
            "operation": "drop",
            "exclude": true,
            "fields": ["feature_id", "time", "reference_time", "streamflow", "crs"]
        },
        {
            "operation": "merge",
            "file_name_pattern": "nwm.t{cycle}z.{ModelOutputType}.{Configuration}.{Region}.nc"
        },
        {
            "operation": "unit_conversion",
            "conversions": [
                {
                    "variable_name": "streamflow",
                    "target_unit": "ft3 s-1"
                }
            ]
        },
        {
            "operation": "save",
            "filename_pattern": "nwm.t{cycle}z.{Configuration}.{ModelOutputType}.{Region}.nc",
            "directory": "{output_path}/"
        }
    ],
    "configuration": "long_range",
    "output_type": "channel_rt",
    "region": "conus",
    "member": null
}
