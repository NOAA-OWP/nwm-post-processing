{
    "operations": [
        {
            "operation": "drop",
            "exclude": true,
            "fields": [
                "crs",
                "SOILSAT_TOP",
                "time",
                "reference_time",
                "x",
                "y"
            ]
        },
        {
            "operation": "subset",
            "mask_variable": "mask",
            "mask_coordinates": ["y", "x"],
            "disable": true,
            "masks": [
                "{mask_path}/processing_mask_1000m_ABRFC.nc",
                "{mask_path}/processing_mask_1000m_C*RFC.nc",
                "{mask_path}/processing_mask_1000m_M*RFC.nc",
                "{mask_path}/processing_mask_1000m_LMRFC.nc",
                "{mask_path}/processing_mask_1000m_N*RFC.nc",
                "{mask_path}/processing_mask_1000m_OHRFC.nc",
                "{mask_path}/processing_mask_1000m_SERFC.nc",
                "{mask_path}/processing_mask_1000m_WGRFC.nc"
            ],
            "identifier_pattern": "(?P<rfc>[A-Z]{5})(?=\\.nc)",
            "output_pattern": "nwm.t{cycle}z.{Configuration}.{ModelOutputType}.f{frame}.{rfc}.nc",
            "each": [
                {
                    "operation": "save",
                    "filename_pattern": "{file_name}",
                    "identifier_pattern": "(?P<rfc>[A-Za-z]{2}[Rr][Ff][Cc])",
                    "directory": "{output_path}/"
                }
            ]
        },
        {
            "operation": "echo",
            "message": "WARNING: The configuration for {source_file} is not complete - individual RFC files have not actually been processed"
        },
        {
            "operation": "save",
            "filename_pattern": "nwm.t{cycle}z.{Configuration}.{ModelOutputType}.f{frame}.ABRFC.nc",
            "directory": "{output_path}/",
            "return_new_paths": false
        },
        {
            "operation": "save",
            "filename_pattern": "nwm.t{cycle}z.{Configuration}.{ModelOutputType}.f{frame}.CBRFC.nc",
            "directory": "{output_path}/",
            "return_new_paths": false
        },
        {
            "operation": "save",
            "filename_pattern": "nwm.t{cycle}z.{Configuration}.{ModelOutputType}.f{frame}.CNRFC.nc",
            "directory": "{output_path}/",
            "return_new_paths": false
        },
        {
            "operation": "save",
            "filename_pattern": "nwm.t{cycle}z.{Configuration}.{ModelOutputType}.f{frame}.MARFC.nc",
            "directory": "{output_path}/",
            "return_new_paths": false
        },
        {
            "operation": "save",
            "filename_pattern": "nwm.t{cycle}z.{Configuration}.{ModelOutputType}.f{frame}.MBRFC.nc",
            "directory": "{output_path}/",
            "return_new_paths": false
        },
        {
            "operation": "save",
            "filename_pattern": "nwm.t{cycle}z.{Configuration}.{ModelOutputType}.f{frame}.NCRFC.nc",
            "directory": "{output_path}/",
            "return_new_paths": false
        },
        {
            "operation": "save",
            "filename_pattern": "nwm.t{cycle}z.{Configuration}.{ModelOutputType}.f{frame}.NERFC.nc",
            "directory": "{output_path}/",
            "return_new_paths": false
        },
        {
            "operation": "save",
            "filename_pattern": "nwm.t{cycle}z.{Configuration}.{ModelOutputType}.f{frame}.NWRFC.nc",
            "directory": "{output_path}/",
            "return_new_paths": false
        },
        {
            "operation": "save",
            "filename_pattern": "nwm.t{cycle}z.{Configuration}.{ModelOutputType}.f{frame}.OHRFC.nc",
            "directory": "{output_path}/",
            "return_new_paths": false
        },
        {
            "operation": "save",
            "filename_pattern": "nwm.t{cycle}z.{Configuration}.{ModelOutputType}.f{frame}.SERFC.nc",
            "directory": "{output_path}/",
            "return_new_paths": false
        },
        {
            "operation": "save",
            "filename_pattern": "nwm.t{cycle}z.{Configuration}.{ModelOutputType}.f{frame}.WGRFC.nc",
            "directory": "{output_path}/"
        }
    ],
    "configuration": "medium_range_blend",
    "output_type": "land",
    "region": "conus",
    "member": "2"
}
