{
    "operations": [
        {
            "operation": "drop",
            "exclude": true,
            "fields": ["feature_id", "time", "reference_time", "streamflow", "crs"]
        },
        {
            "operation": "on_each",
            "comment": "Add upstreamflow to each input file by calling 'post_processing.transform.calculate_upstream_flow.calculate_upstream_flow' on each",
            "on_each": [
                {
                    "operation": "function",
                    "function_name": "post_processing.transform.calculate_upstream_flow.calculate_upstream_flow",
                    "comment": "This should end up calling `calculate_upstream_flow(input_path=data, output_path=data, routelink_path='{application_path}/RouteLink_CONUS.nc')`",
                    "kwargs": {
                        "routelink_path": "{routelink_path}/RouteLink_PRVI.nc",
                        "routelink_from_variable": "from",
                        "output_path": "{work_directory}/upstream.{input_name}"
                    },
                    "argument_mapping": {
                        "input_path": "data"
                    }
                }
            ]
        },
        {
            "operation": "merge",
            "file_name_pattern": "nwm.t{reference_time__date}{cycle}z.{ModelOutputType}.{Configuration}.{Region}.nc"
        },
        {
            "operation": "branch",
            "branches": {
                "WMS": [
                    {
                        "operation": "drop",
                        "fields": ["upstreamflow"]
                    },
                    {
                        "operation": "save",
                        "filename_pattern": "nwm.t{reference_time__date}{cycle}z.{Configuration}.{ModelOutputType}.{Region}.serfc.nc",
                        "directory": "{output_path}/WMS/"
                    }
                ],
                "RFC": [
                    {
                        "operation": "extract",
                        "dimension": "feature_id",
                        "mask_coordinate": "feature_id",
                        "masks": [
                            "resources/masks/prvi.serfc.nc"
                        ],
                        "identifier_pattern": "^(?P<region>\\w+(\\.(?P<rfc>[MmAaLlCcNnPpWwOoSsHh][BbPpNnMmAaCcEeWwHhRrGg]([Rr][Ff][Cc]|[Vv][Ii])))?)",
                        "output_pattern": "split.nwm.t{reference_time__date}{cycle}z.{Configuration}.{ModelOutputType}.puertorico.nc",
                        "each": [
                            {
                                "operation": "peek",
                                "show_state": false,
                                "show_summary": false
                            },
                            {
                                "operation": "rename",
                                "mapping": {
                                    "feature_id": "station_id"
                                },
                                "output_pattern": "renamed.{file_name}"
                            },
                            {
                                "operation": "rename",
                                "rename_variable": false,
                                "mapping": {
                                    "feature_id": "station"
                                },
                                "output_pattern": "renamed.{file_name}"
                            },
                            {
                                "operation": "save",
                                "filename_pattern": "nwm.t{reference_time__date}{cycle}z.{Configuration}.{ModelOutputType}.puertorico.serfc.nc",
                                "identifier_pattern": "(?P<rfc>[A-Za-z]{2}[Rr][Ff][Cc])",
                                "directory": "{output_path}/RFC/{RFC}/"
                            }
                        ]
                    }
                ]
            }
        }
    ],
    "configuration": "short_range",
    "output_type": "channel_rt",
    "region": "puertorico",
    "member": null
}
