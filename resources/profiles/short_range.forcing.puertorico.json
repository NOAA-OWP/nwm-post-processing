{
    "operations": [
        {
            "operation": "drop",
            "exclude": true,
            "fields": [
                "time",
                "x",
                "y",
                "reference_time",
                "crs",
                "RAINRATE",
                "T2D"
            ]
        },
        {
            "operation": "total_over_time",
            "rate_variable_name": "RAINRATE",
            "total_variable_name": "PRECIP",
            "output_unit": "in",
            "input_quantity_unit": "mm",
            "input_time_unit": "seconds",
            "time_unit": "hours",
            "amount_of_time": 1,
            "total_variable_attributes": {
                "standard_name": "rainfall_amount",
                "long_name": "accumulated liquid precipitation"
            }
        },
        {
            "operation": "drop",
            "fields": [
                "RAINRATE"
            ]
        },
        {
            "operation": "branch",
            "branches": {
                "WMS": [
                    {
                        "operation": "drop",
                        "fields": [
                            "T2D"
                        ]
                    },
                    {
                        "operation": "reproject",
                        "reference_dataset_path": "{resource_path}/projections/prvi_mercator.nc"
                    },
                    {
                        "operation": "branch",
                        "branches": {
                            "daily": [
                                {
                                    "operation": "group_by",
                                    "time_unit": "days",
                                    "on_each": [
                                        {
                                            "operation": "stream",
                                            "streams": [
                                                {
                                                    "input_variable": "PRECIP",
                                                    "calculation_type": "mean"
                                                }
                                            ],
                                            "output_pattern": "nwm.t{cycle}z.{Configuration}.{ModelOutputType}.{group}.{Region}.nc"
                                        }
                                    ]
                                }
                            ],
                            "full": [
                                {
                                    "operation": "group_by",
                                    "time_unit": "hours",
                                    "amount_of_time": 48,
                                    "on_each": [
                                        {
                                            "operation": "stream",
                                            "streams": [
                                                {
                                                    "input_variable": "PRECIP",
                                                    "calculation_type": "mean"
                                                }
                                            ],
                                            "output_pattern": "nwm.t{cycle}z.{Configuration}.{ModelOutputType}.{group}.{Region}.nc"
                                        }
                                    ]
                                }
                            ]
                        }
                    },
                    {
                        "operation": "save",
                        "directory": "{output_path}/",
                        "filename_pattern": "{file_name}"
                    }
                ],
                "RFC": [
                    {
                        "operation": "rename",
                        "mapping": {
                            "T2D": "TEMPERATURE"
                        }
                    },
                    {
                        "operation": "unit_conversion",
                        "conversions": [
                            {
                                "variable_name": "TEMPERATURE",
                                "target_unit": "C"
                            }
                        ]
                    },
                    {
                        "operation": "reproject",
                        "reference_dataset_path": "{resource_path}/projections/prvi_sphere_lambert.nc"
                    },
                    {
                        "operation": "save",
                        "filename_pattern": "nwm.t{cycle}z.{Configuration}.{ModelOutputType}.{slice}.puertorico.serfc.nc",
                        "directory": "{output_path}/"
                    }
                ]
            }
        }

    ],
    "configuration": "short_range",
    "output_type": "forcing",
    "region": "puertorico",
    "member": null
}
