{
    "version": 1,
    "disable_existing_loggers": false,
    "formatters": {
        "simple": {
            "format": "[%(asctime)s] %(levelname)s %(name)s: %(message)s",
            "datefmt": "%Y-%m-%d %H:%M:%S%z"
        },
        "detailed": {
            "format":"[%(asctime)s] %(levelname)s %(name)s %(filename)s #%(lineno)d: %(message)s",
            "datefmt": "%Y-%m-%d %H:%M:%S%z"
        }
    },
    "filters": {
        "exclude_errors": {
            "()": "post_processing.utilities.logging.ErrorExclusionFilter"
        },
        "only_errors": {
            "()": "post_processing.utilities.logging.OnlyErrorFilter"
        }
    },
    "handlers": {
        "stdout": {
            "class": "logging.StreamHandler",
            "level": "DEBUG",
            "formatter": "simple",
            "stream": "ext://sys.stdout",
            "filters": [
                "exclude_errors"
            ]
        },
        "stderr": {
            "class": "logging.StreamHandler",
            "level": "ERROR",
            "formatter": "detailed",
            "stream": "ext://sys.stderr",
            "filters": [
                "only_errors"
            ]
        }
    },
    "root": {
        "level": "INFO",
        "handlers": [
            "stdout",
            "stderr"
        ]
    }
}
